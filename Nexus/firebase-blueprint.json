{
  "entities": {
    "ContactRequest": {
      "title": "Contact Request",
      "description": "A request for contact or quote from a potential client.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the prospect"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the prospect"
        },
        "service": {
          "type": "string",
          "description": "Service they are interested in"
        },
        "message": {
          "type": "string",
          "description": "Additional details about the project"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the request was submitted"
        }
      },
      "required": ["name", "email", "createdAt"]
    },
    "NewsletterSubscriber": {
      "title": "Newsletter Subscriber",
      "description": "A subscriber to the newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the subscriber"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the subscription was submitted"
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/contact_requests/{requestId}": {
      "schema": {
        "$ref": "#/entities/ContactRequest"
      },
      "description": "Stores contact requests"
    },
    "/newsletter_subscribers/{subscriberId}": {
      "schema": {
        "$ref": "#/entities/NewsletterSubscriber"
      },
      "description": "Stores newsletter subscribers"
    }
  }
}
